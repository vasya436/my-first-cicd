/etc/keepalived/keepalived.conf                                     


global_defs {
    script_user root
    enable_script_security
}

vrrp_script chk_web {
    script "/usr/local/bin/check_web.sh"
    interval 3
    fall 2
    rise 2
}

vrrp_instance VI_1 {
    state MASTER
    interface enp0s3
    virtual_router_id 15
    priority 255
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass mypass123
    }

    virtual_ipaddress {
        192.168.111.15/24
    }

    track_script {
        chk_web
    }
}

/etc/keepalived/keepalived_backup.conf

vrrp_instance VI_1 {
    state BACKUP
    interface enp0s3
    virtual_router_id 15
    priority 100
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass mypass123
    }

    virtual_ipaddress {
        192.168.111.15/24
    }
}

